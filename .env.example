# ── Twitter v2 API ─────────────────────────────────────────
# Required for sentiment scanning. Get from developer.twitter.com (Basic tier+)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# Legacy v1.1 keys (no longer used by the agent)
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret

# ── Telegram ───────────────────────────────────────────────
# Required for alert delivery. Create a bot via @BotFather.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# The chat/channel ID to send alerts to (use @username or numeric ID)
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Blockchain ─────────────────────────────────────────────
WEB3_PROVIDER_URL=https://mainnet.infura.io/v3/your_infura_key
ETHERSCAN_API_KEY=your_etherscan_api_key
BSC_RPC_URL=https://bsc-dataseed.binance.org/

# ── DEX / Token Data ───────────────────────────────────────
DEXSCREENER_API_URL=https://api.dexscreener.com/latest
# Optional — increases CoinGecko rate limits
COINGECKO_API_KEY=your_coingecko_api_key

# ── Redis ──────────────────────────────────────────────────
# Used for alert deduplication. Agent falls back to in-process cache if unavailable.
REDIS_URL=redis://localhost:6379/0

# ── Whale Watchlist ────────────────────────────────────────
# Path to JSON file containing whale wallet addresses
WHALE_WATCHLIST_PATH=data/whales.json

# ── Price Oracle ───────────────────────────────────────────
# How long (seconds) to cache ETH/BNB prices before refreshing from CoinGecko
ETH_PRICE_TTL_SECONDS=300

# ── Agent Settings ─────────────────────────────────────────
SCAN_INTERVAL_SECONDS=60
# Minimum confidence score (0.0–1.0) for a signal to trigger an alert
SENTIMENT_THRESHOLD=0.6
# Minimum USD value for a whale wallet transaction to be flagged
WHALE_WALLET_MIN_USD=100000
LOG_LEVEL=INFO

# ── Prometheus ─────────────────────────────────────────────
# Port for the /metrics endpoint (scraped by Prometheus)
METRICS_PORT=8000

# ── Nansen ─────────────────────────────────────────────────
# Required for smart money netflows and token screener (paid API)
# Get your key at https://app.nansen.ai
NANSEN_API_KEY=your_nansen_api_key

# ── Hyperliquid ────────────────────────────────────────────
# Public API — no key required
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz/info
# Minimum open interest (USD) to flag a perp as a signal
HL_MIN_OI_USD=5000000
# Funding rate threshold (per 8h) — flag when |rate| exceeds this
HL_FUNDING_THRESHOLD=0.0003

# ── Exchange Listing Detection ─────────────────────────────
# Comma-separated chains to watch for pre-listing deposit activity
LISTING_WATCH_CHAINS=ethereum
